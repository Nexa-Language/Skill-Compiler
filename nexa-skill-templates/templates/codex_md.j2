---
name: {{ name }}
description: {{ clean_description }}
version: {{ version }}
{% if hitl_required %}
hitl_required: true
{% endif %}
security_level: {{ security_level }}
{% if !mcp_servers.is_empty() %}
mcp_servers:
{% for server in mcp_servers %}
  - {{ server }}
{% endfor %}
{% endif %}
mode: {{ skill_mode }}
---

<skill name="{{ name }}">
  <instructions>
{{ description }}

{% if !extra_sections.is_empty() %}
{% for section in extra_sections %}
{% match section.level %}
{% when 1 %}# {{ section.title }}
{% when 2 %}## {{ section.title }}
{% when 3 %}### {{ section.title }}
{% when 4 %}#### {{ section.title }}
{% when 5 %}##### {{ section.title }}
{% when 6 %}###### {{ section.title }}
{% else %}### {{ section.title }}
{% endmatch %}
{{ section.content }}

{% endfor %}
{% endif %}
  </instructions>

{% if !anti_skill_constraints.is_empty() %}
  <constraints>
{% for constraint in anti_skill_constraints %}
    <forbidden>{{ constraint.content }}{{ constraint.level_marker }}</forbidden>
{% endfor %}
  </constraints>

{% endif %}
{% if !approaches.is_empty() %}
  <approaches>
{% for approach in approaches %}
    <approach name="{{ approach.name }}">
      <description>{{ approach.description }}</description>
      <instructions>{{ approach.instructions }}</instructions>
    </approach>
{% endfor %}
  </approaches>

{% endif %}
{% if !pre_conditions.is_empty() %}
  <pre_conditions>
{% for cond in pre_conditions %}
    <condition>{{ cond }}</condition>
{% endfor %}
  </pre_conditions>

{% endif %}
{% if !permissions.is_empty() %}
  <permissions>
{% for perm in permissions %}
    <permission kind="{{ perm.kind_name }}" scope="{{ perm.scope }}"{% if perm.read_only %} read_only="true"{% endif %}>{{ perm.description }}</permission>
{% endfor %}
  </permissions>

{% endif %}
{% if !examples.is_empty() %}
  <examples>
{% for example in examples %}
    <example{% if !example.title.is_empty() %} title="{{ example.title }}"{% endif %}>
      <input>{{ example.user_input }}</input>
      <output>{{ example.agent_response }}</output>
    </example>
{% endfor %}
  </examples>

{% endif %}
{% if !fallbacks.is_empty() %}
  <fallbacks>
{% for fb in fallbacks %}
    <strategy>{{ fb }}</strategy>
{% endfor %}
  </fallbacks>

{% endif %}
{% if !post_conditions.is_empty() %}
  <post_conditions>
{% for cond in post_conditions %}
    <condition>{{ cond }}</condition>
{% endfor %}
  </post_conditions>

{% endif %}
  <output_format>
After completion, format output as a clear, structured response.
Use appropriate formatting: headers, bullet points, or code blocks as needed.
For CI/CD pipeline integration, use `-p` non-interactive mode.

Before considering the task complete, verify ALL of the following:
- Output file exists at the specified path
- Output format matches the required schema
- All computed values are present (no empty cells unless explicitly allowed)
- Edge cases handled: empty inputs, missing data, API failures
{% if !post_conditions.is_empty() %}
{% for cond in post_conditions %}
- {{ cond }}
{% endfor %}
{% endif %}
  </output_format>

  <edge_cases>
- If input is ambiguous: Ask user for clarification before proceeding
- If external API fails: Report error, do not fabricate data
- If required data missing: Halt and notify user
  </edge_cases>
</skill>
